{% extends 'base.html.twig' %}

{% block title %}Create Account – FTIC{% endblock %}

{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# Left panel #}
    <div class="hidden lg:flex w-1/2 flex-col justify-between p-12" style="background-color:#0b3612;">
        <a href="{{ path('app_home') }}" class="text-white text-2xl font-extrabold tracking-tight">FTIC</a>
        <div>
            <p class="text-white text-3xl font-bold leading-snug mb-4">Far Eastern University<br>Training &amp; Innovation Center</p>
            <p class="text-sm" style="color:#a8c9af;">Create your student account to get started.</p>
        </div>
        <p class="text-xs" style="color:#6a9e74;">&copy; {{ "now"|date("Y") }} FTIC. All rights reserved.</p>
    </div>

    {# Right panel #}
    <div class="flex flex-1 flex-col items-center justify-center px-6 py-12 bg-white">
        <div class="w-full max-w-sm">

            {# Mobile logo #}
            <div class="lg:hidden text-center mb-8">
                <a href="{{ path('app_home') }}" class="text-2xl font-extrabold tracking-tight" style="color:#0b3612;">FTIC</a>
            </div>

            <h1 class="text-2xl font-bold text-gray-900 mb-1">Create an account</h1>
            <p class="text-sm text-gray-400 mb-8">Student registration — free to join</p>

            {% for message in app.flashes('success') %}
                <div class="mb-5 bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3">{{ message }}</div>
            {% endfor %}

            {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

                {# First Name / Last Name #}
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        {{ form_label(form.firstName, 'First Name', {label_attr: {class: 'block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5'}}) }}
                        {{ form_widget(form.firstName, {attr: {
                            class: 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition',
                            placeholder: 'Juan'
                        }}) }}
                        {% if form.firstName.vars.errors|length %}
                            <p class="mt-1 text-xs text-red-600">{{ form_errors(form.firstName) }}</p>
                        {% endif %}
                    </div>
                    <div>
                        {{ form_label(form.lastName, 'Last Name', {label_attr: {class: 'block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5'}}) }}
                        {{ form_widget(form.lastName, {attr: {
                            class: 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition',
                            placeholder: 'dela Cruz'
                        }}) }}
                        {% if form.lastName.vars.errors|length %}
                            <p class="mt-1 text-xs text-red-600">{{ form_errors(form.lastName) }}</p>
                        {% endif %}
                    </div>
                </div>

                {# Email #}
                <div>
                    {{ form_label(form.email, 'Email Address', {label_attr: {class: 'block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5'}}) }}
                    {{ form_widget(form.email, {attr: {
                        class: 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition',
                        placeholder: 'you@example.com'
                    }}) }}
                    {% if form.email.vars.errors|length %}
                        <p class="mt-1 text-xs text-red-600">{{ form_errors(form.email) }}</p>
                    {% endif %}
                </div>

                {# Password #}
                <div>
                    {{ form_label(form.plainPassword.first, 'Password', {label_attr: {class: 'block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5'}}) }}
                    <div class="relative">
                        {{ form_widget(form.plainPassword.first, {attr: {
                            class: 'w-full px-4 py-3 pr-11 rounded-lg border border-gray-200 bg-gray-50 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition',
                            placeholder: '••••••••'
                        }}) }}
                        <button type="button" onclick="togglePwd(this)"
                                class="absolute inset-y-0 right-3 flex items-center text-gray-400 hover:text-gray-600">
                            {# eye-open #}
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            {# eye-off #}
                            <svg class="w-5 h-5" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 012.163-3.592M6.53 6.53A9.97 9.97 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.05 10.05 0 01-4.423 5.311M3 3l18 18"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.first.vars.errors|length %}
                        <p class="mt-1 text-xs text-red-600">{{ form_errors(form.plainPassword.first) }}</p>
                    {% endif %}
                </div>

                {# Confirm Password #}
                <div>
                    {{ form_label(form.plainPassword.second, 'Confirm Password', {label_attr: {class: 'block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5'}}) }}
                    <div class="relative">
                        {{ form_widget(form.plainPassword.second, {attr: {
                            class: 'w-full px-4 py-3 pr-11 rounded-lg border border-gray-200 bg-gray-50 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition',
                            placeholder: '••••••••'
                        }}) }}
                        <button type="button" onclick="togglePwd(this)"
                                class="absolute inset-y-0 right-3 flex items-center text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg class="w-5 h-5" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 012.163-3.592M6.53 6.53A9.97 9.97 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.05 10.05 0 01-4.423 5.311M3 3l18 18"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.vars.errors|length %}
                        <p class="mt-1 text-xs text-red-600">{{ form_errors(form.plainPassword) }}</p>
                    {% endif %}
                </div>

                <button type="submit"
                        class="w-full py-3 rounded-lg text-white text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-offset-2"
                        style="background-color:#0b3612;"
                        onmouseover="this.style.backgroundColor='#5c8d67'"
                        onmouseout="this.style.backgroundColor='#0b3612'">
                    Create Account
                </button>

            {{ form_end(form) }}

            <p class="mt-6 text-center text-sm text-gray-400">
                Already have an account?
                <a href="{{ path('app_login') }}" class="font-semibold hover:underline" style="color:#0b3612;">Sign in</a>
            </p>

            <p class="mt-4 text-center text-xs text-gray-400">
                <a href="{{ path('app_home') }}" class="hover:underline" style="color:#0b3612;">&larr; Back to home</a>
            </p>
        </div>
    </div>

</div>

<script>
function togglePwd(btn) {
    const input  = btn.closest('.relative').querySelector('input');
    const svgs   = btn.querySelectorAll('svg');
    const showing = input.type === 'text';
    input.type           = showing ? 'password' : 'text';
    svgs[0].style.display = showing ? '' : 'none';  // eye-open
    svgs[1].style.display = showing ? 'none' : '';  // eye-off
}
</script>
{% endblock %}
