{% extends 'base.html.twig' %}

{% block title %}Sign In – FTIC{% endblock %}

{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-feu-pale to-[#d4e8d7] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">

        {# Logo / Brand #}
        <div class="text-center mb-8">
            <a href="{{ path('app_home') }}" class="text-3xl font-extrabold text-feu-dark tracking-tight">FTIC</a>
            <p class="text-gray-500 mt-2 text-sm">Sign in to your account</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">

            {% if error %}
                <div class="mb-5 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 flex items-start gap-2">
                    <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-5">
                    <label for="inputEmail" class="block text-sm font-medium text-gray-700 mb-1.5">Email address</label>
                    <input type="email"
                           id="inputEmail"
                           name="_username"
                           value="{{ last_username }}"
                           required
                           autofocus
                           autocomplete="email"
                           class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-feu-light focus:border-transparent text-sm transition"
                           placeholder="you@example.com">
                </div>

                <div class="mb-6">
                    <div class="flex justify-between items-center mb-1.5">
                        <label for="inputPassword" class="block text-sm font-medium text-gray-700">Password</label>
                    </div>
                    <input type="password"
                           id="inputPassword"
                           name="_password"
                           required
                           autocomplete="current-password"
                           class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-feu-light focus:border-transparent text-sm transition"
                           placeholder="••••••••">
                </div>

                <div class="flex items-center mb-6">
                    <input type="checkbox" id="remember_me" name="_remember_me"
                           class="h-4 w-4 text-feu-dark border-gray-300 rounded focus:ring-feu-light">
                    <label for="remember_me" class="ml-2 text-sm text-gray-600">Remember me</label>
                </div>

                <button type="submit"
                        class="w-full bg-feu-dark hover:bg-[#0d4016] text-white font-semibold py-2.5 rounded-lg transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-feu-light text-sm">
                    Sign In
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a href="{{ path('app_home') }}" class="text-feu-dark hover:text-feu-light font-medium transition">&larr; Back to home</a>
        </p>

    </div>
</div>
{% endblock %}
