{% extends 'admin/base.html.twig' %}

{% block title %}User Management – FTIC Admin{% endblock %}

{% block body %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">User Management</h1>
        <p class="text-sm text-gray-500 mt-1">Manage admin, trainer and student accounts</p>
    </div>
    <a href="{{ path('app_admin_users_new') }}"
       class="inline-flex items-center gap-2 text-sm font-medium text-white px-4 py-2 rounded-lg shadow-sm transition"
       style="background-color:#0b3612;" onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add User
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900">All Users</h2>
        <span class="text-xs text-gray-400">{{ users|length }} user{{ users|length != 1 ? 's' : '' }}</span>
    </div>
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-gray-100 text-left text-xs text-gray-400 uppercase tracking-wide">
                <th class="px-6 py-3 font-medium">Name</th>
                <th class="px-6 py-3 font-medium">Email</th>
                <th class="px-6 py-3 font-medium">Role</th>
                <th class="px-6 py-3 font-medium">Status</th>
                <th class="px-6 py-3 font-medium">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            {% for u in users %}
            <tr class="hover:bg-gray-50 transition">
                <td class="px-6 py-4 font-medium text-gray-900">{{ u.fullName ?: '—' }}</td>
                <td class="px-6 py-4 text-gray-500">{{ u.email }}</td>
                <td class="px-6 py-4">
                    {% if u.role == 'admin' %}
                        <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full bg-purple-100 text-purple-700">Admin</span>
                    {% elseif u.role == 'trainer' %}
                        <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color:#e8f2ea;color:#0b3612;">Trainer</span>
                    {% else %}
                        <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full bg-blue-100 text-blue-700">Student</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4">
                    {% if u.role == 'student' %}
                        {% if u.isConfirmed %}
                            <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color:#e8f2ea;color:#0b3612;">Confirmed</span>
                        {% else %}
                            <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-700">Pending</span>
                        {% endif %}
                    {% else %}
                        <span class="text-xs text-gray-300">—</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 flex items-center gap-2">
                    <a href="{{ path('app_admin_users_edit', {id: u.id}) }}"
                       class="text-xs font-semibold px-3 py-1.5 rounded-lg text-white transition"
                       style="background-color:#0b3612;" onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
                        Edit
                    </a>
                    {% if u.id != app.user.id %}
                    <form method="post" action="{{ path('app_admin_users_delete', {id: u.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ u.id) }}">
                        <button type="button"
                                onclick="openConfirmModal(this.closest('form'), 'This will permanently delete the account for &quot;{{ u.fullName ?: u.email }}&quot;. This action cannot be undone.', 'Delete User')"
                                class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 transition">
                            Delete
                        </button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-12 text-center">
                    <div class="flex flex-col items-center text-gray-400">
                        <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <p class="text-sm font-medium">No users found</p>
                        <a href="{{ path('app_admin_users_new') }}" class="text-xs mt-2 underline" style="color:#0b3612;">Add the first user</a>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Delete confirmation modal handled via onsubmit confirm() #}
{% endblock %}
