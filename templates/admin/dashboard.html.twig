{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard – FTIC{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Admin Dashboard</h1>
            <p class="text-gray-500 mt-1">Welcome back, <span class="font-medium text-feu-dark">{{ user.displayName }}</span></p>
        </div>
        <span class="inline-flex items-center gap-1.5 bg-feu-dark text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"/></svg>
            Admin
        </span>
    </div>

    {# Stats #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Total Users</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Across all roles</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Trainers</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Active trainers</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Students</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Enrolled students</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Date</p>
            <p class="text-xl font-bold text-gray-900">{{ "now"|date("M d, Y") }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Admin Actions #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-4">Admin Actions</h2>
            <ul class="space-y-2">
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Manage Users
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    Manage Courses
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    View Reports
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    System Settings
                </a></li>
            </ul>
        </div>

        {# Recent Activity #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 lg:col-span-2">
            <h2 class="text-base font-semibold text-gray-900 mb-4">System Activity</h2>
            <div class="flex flex-col items-center justify-center py-12 text-center text-gray-400">
                <svg class="w-14 h-14 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <p class="text-sm font-medium text-gray-500">No recent activity</p>
                <p class="text-xs text-gray-400 mt-1">System events will appear here</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
