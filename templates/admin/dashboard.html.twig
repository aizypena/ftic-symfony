{% extends 'admin/base.html.twig' %}

{% block title %}Admin Dashboard – FTIC{% endblock %}

{% block body %}
{# Page header #}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">Welcome back, <span class="font-medium" style="color:#0b3612;">{{ user.displayName }}</span></p>
</div>

{# Stats #}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
            <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Total Users</p>
            <p class="text-2xl font-bold text-gray-900">{{ totalUsers }}</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
            <svg class="w-6 h-6" style="color:#5c8d67;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Applications</p>
            <p class="text-2xl font-bold text-gray-900">{{ pendingCount }}</p>
            <p class="text-xs text-gray-400">pending</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
            <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        </div>
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Courses</p>
            <p class="text-2xl font-bold text-gray-900">{{ totalCourses }}</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
            <svg class="w-6 h-6" style="color:#5c8d67;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Today</p>
            <p class="text-lg font-bold text-gray-900">{{ "now"|date("M d, Y") }}</p>
        </div>
    </div>
</div>

{# ── Announcements ── #}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

    {# Post form #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Post Announcement</h2>
        <form method="post" action="{{ path('app_admin_announcement_create') }}" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="_token" value="{{ csrf_token('announcement-create') }}">
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Title</label>
                <input type="text" name="title" required maxlength="255"
                       placeholder="Announcement title…"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Message</label>
                <textarea name="content" required rows="4"
                          placeholder="Write your message here…"
                          class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 resize-none"></textarea>
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">
                    Image <span class="font-normal text-gray-400 normal-case">(optional)</span>
                </label>
                <input type="file" name="image" accept="image/*" onchange="previewImage(this, 'create-img-preview')" class="w-full text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:text-white file:cursor-pointer" style="file:background-color:#0b3612;">
                <img id="create-img-preview" src="" alt="" style="display:none; margin-top:8px; max-height:140px; width:100%; object-fit:cover; border-radius:8px; border:1px solid #e5e7eb;">
            </div>
            <button type="submit"
                    class="w-full py-2.5 text-sm font-semibold text-white rounded-lg transition"
                    style="background-color:#0b3612;"
                    onmouseover="this.style.backgroundColor='#5c8d67'"
                    onmouseout="this.style.backgroundColor='#0b3612'">
                Post Announcement
            </button>
        </form>
    </div>

    {# Posted announcements list #}
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Posted Announcements</h2>
        </div>
        {% if announcements|length > 0 %}
        <ul class="divide-y divide-gray-50">
            {% for ann in announcements %}
            <li class="px-6 py-4 flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 mb-1">
                        <p class="text-sm font-semibold text-gray-900">{{ ann.title }}</p>
                        <span class="text-xs text-gray-400">{{ ann.createdAt|date('M d, Y · g:i A') }}</span>
                    </div>
                    <p class="text-sm text-gray-500 whitespace-pre-line mb-2">{{ ann.content }}</p>
                    {% if ann.imageFilename %}
                    <img src="{{ asset('uploads/announcements/' ~ ann.imageFilename) }}"
                         alt="Announcement image"
                         style="max-height:180px; max-width:100%; object-fit:cover; border-radius:8px; border:1px solid #e5e7eb;">
                    {% endif %}
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    {# Edit button #}
                    <button type="button"
                            onclick="openEditModal({{ ann.id }}, {{ ann.title|json_encode }}, {{ ann.content|json_encode }}, {{ ann.imageFilename ? asset('uploads/announcements/' ~ ann.imageFilename)|json_encode : 'null' }})"
                            class="w-8 h-8 flex items-center justify-center rounded-lg bg-blue-50 text-blue-400 hover:bg-blue-100 hover:text-blue-600 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </button>
                    {# Delete button #}
                    <form method="post" action="{{ path('app_admin_announcement_delete', {id: ann.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('announcement-delete-' ~ ann.id) }}">
                        <button type="button"
                                onclick="openConfirmModal(this.closest('form'), 'Delete this announcement?', 'Delete Announcement')"
                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-50 text-red-400 hover:bg-red-100 hover:text-red-600 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <div class="flex flex-col items-center justify-center py-10 text-center text-gray-400">
            <svg class="w-10 h-10 mb-2 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
            </svg>
            <p class="text-sm font-medium">No announcements posted yet</p>
        </div>
        {% endif %}
    </div>

</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="flex items-center justify-between mb-5">
        <h2 class="text-base font-semibold text-gray-900">Recent Applications</h2>
        <a href="{{ path('app_admin_applications') }}" class="text-sm font-medium hover:underline" style="color:#0b3612;">View all</a>
    </div>
    {% if recentApps|length > 0 %}
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-gray-100 text-left text-xs text-gray-400 uppercase tracking-wide">
                <th class="pb-3 font-medium">Name</th>
                <th class="pb-3 font-medium">Email</th>
                <th class="pb-3 font-medium text-right">Action</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            {% for student in recentApps %}
            <tr class="hover:bg-gray-50 transition">
                <td class="py-3 font-medium text-gray-900">{{ student.fullName ?: '—' }}</td>
                <td class="py-3 text-gray-500">{{ student.email }}</td>
                <td class="py-3 text-right">
                    <form method="post" action="{{ path('app_admin_application_confirm', {id: student.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('confirm-' ~ student.id) }}">
                        <button type="submit"
                                class="text-xs font-semibold px-3 py-1.5 rounded-lg text-white transition"
                                style="background-color:#0b3612;"
                                onmouseover="this.style.backgroundColor='#5c8d67'"
                                onmouseout="this.style.backgroundColor='#0b3612'">
                            Approve
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="flex flex-col items-center justify-center py-10 text-center">
        <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <p class="text-sm font-medium text-gray-500">No pending applications</p>
    </div>
    {% endif %}
</div>

{# ── Edit Announcement Modal ── #}
<div id="edit-ann-modal"
     style="display:none; position:fixed; inset:0; z-index:999; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;"
     onclick="if(event.target===this) closeEditModal()">
    <div style="background:#fff; border-radius:1rem; padding:28px; width:100%; max-width:520px; margin:16px; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
            <h3 style="font-size:16px; font-weight:700; color:#111827; margin:0;">Edit Announcement</h3>
            <button type="button" onclick="closeEditModal()"
                    style="width:32px; height:32px; border-radius:8px; border:none; background:#f3f4f6; cursor:pointer; display:flex; align-items:center; justify-content:center; color:#6b7280;"
                    onmouseover="this.style.background='#e5e7eb'" onmouseout="this.style.background='#f3f4f6'">
                <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <form id="edit-ann-form" method="post" action="" enctype="multipart/form-data" class="space-y-4">
            <input type="hidden" name="_token" id="edit-ann-token" value="">
            <input type="hidden" name="remove_image" id="edit-ann-remove" value="0">
            <div>
                <label style="display:block; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:6px;">Title</label>
                <input type="text" name="title" id="edit-ann-title" required maxlength="255"
                       style="width:100%; padding:9px 12px; font-size:14px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb; box-sizing:border-box; outline:none;">
            </div>
            <div>
                <label style="display:block; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:6px;">Message</label>
                <textarea name="content" id="edit-ann-content" required rows="5"
                          style="width:100%; padding:9px 12px; font-size:14px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb; box-sizing:border-box; outline:none; resize:vertical;"></textarea>
            </div>
            {# Current image preview #}
            <div id="edit-ann-current-img-wrap" style="display:none;">
                <label style="display:block; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:6px;">Current Image</label>
                <div style="position:relative; display:inline-block;">
                    <img id="edit-ann-current-img" src="" alt="" style="max-height:120px; max-width:100%; object-fit:cover; border-radius:8px; border:1px solid #e5e7eb; display:block;">
                    <button type="button" onclick="removeEditImage()"
                            title="Remove image"
                            style="position:absolute; top:-8px; right:-8px; width:22px; height:22px; background:#ef4444; border:none; border-radius:50%; color:#fff; font-size:14px; line-height:22px; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:0;">&#x2715;</button>
                </div>
            </div>
            {# New image upload #}
            <div>
                <label style="display:block; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:6px;">
                    Image <span style="font-weight:400; color:#9ca3af; text-transform:none;">(optional)</span>
                </label>
                <input type="file" name="image" id="edit-ann-image" accept="image/*" onchange="previewImage(this, 'edit-img-new-preview')" style="width:100%; font-size:13px; color:#6b7280;">
                <img id="edit-img-new-preview" src="" alt="" style="display:none; margin-top:8px; max-height:120px; width:100%; object-fit:cover; border-radius:8px; border:1px solid #e5e7eb;">
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:4px;">
                <button type="button" onclick="closeEditModal()"
                        style="padding:9px 20px; font-size:13px; font-weight:600; border-radius:8px; border:1px solid #e5e7eb; background:#fff; color:#374151; cursor:pointer;"
                        onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='#fff'">
                    Cancel
                </button>
                <button type="submit"
                        style="padding:9px 20px; font-size:13px; font-weight:600; border-radius:8px; border:none; background:#0b3612; color:#fff; cursor:pointer;"
                        onmouseover="this.style.background='#5c8d67'" onmouseout="this.style.background='#0b3612'">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

{# CSRF tokens + edit URLs for each announcement — read by JS #}
<div id="edit-ann-data" style="display:none;">
    {% for ann in announcements %}
    <span data-id="{{ ann.id }}"
          data-url="{{ path('app_admin_announcement_edit', {id: ann.id}) }}"
          data-token="{{ csrf_token('announcement-edit-' ~ ann.id) }}"></span>
    {% endfor %}
</div>

<script>
function openEditModal(id, title, content, imageUrl) {
    var data  = document.querySelector('#edit-ann-data [data-id="' + id + '"]');
    var form  = document.getElementById('edit-ann-form');
    form.action = data.dataset.url;
    form.reset();
    document.getElementById('edit-ann-token').value   = data.dataset.token;
    document.getElementById('edit-ann-title').value   = title;
    document.getElementById('edit-ann-content').value = content;
    document.getElementById('edit-ann-remove').value  = '0';
    // Reset new image preview
    var newPreview = document.getElementById('edit-img-new-preview');
    newPreview.src = ''; newPreview.style.display = 'none';
    // Show/hide current image
    var wrap = document.getElementById('edit-ann-current-img-wrap');
    var img  = document.getElementById('edit-ann-current-img');
    if (imageUrl) {
        img.src = imageUrl;
        wrap.style.display = 'block';
    } else {
        img.src = '';
        wrap.style.display = 'none';
    }
    var modal = document.getElementById('edit-ann-modal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    document.getElementById('edit-ann-title').focus();
}
function removeEditImage() {
    document.getElementById('edit-ann-remove').value = '1';
    document.getElementById('edit-ann-current-img-wrap').style.display = 'none';
}
function previewImage(input, previewId) {
    var preview = document.getElementById(previewId);
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) { preview.src = e.target.result; preview.style.display = 'block'; };
        reader.readAsDataURL(input.files[0]);
    } else {
        preview.src = ''; preview.style.display = 'none';
    }
}
function closeEditModal() {
    document.getElementById('edit-ann-modal').style.display = 'none';
    document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeEditModal();
});
</script>

{% endblock %}
