{% extends 'admin/base.html.twig' %}

{% block title %}Applications – FTIC Admin{% endblock %}

{% block body %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Applications</h1>
        <p class="text-sm text-gray-500 mt-1">Review and manage all applicant submissions</p>
    </div>
</div>

{# Pending stat card #}
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4 mb-6 max-w-xs">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
        <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
    </div>
    <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Pending</p>
        <p class="text-2xl font-bold text-gray-900">0</p>
    </div>
</div>

{# Applicant list table #}
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900">Applicant List</h2>
        <div class="relative">
            <input type="text" placeholder="Search applicants…"
                   class="text-sm border border-gray-200 rounded-lg py-1.5 pl-8 pr-3 focus:outline-none focus:ring-2 focus:border-transparent"
                   style="--tw-ring-color:#5c8d67;">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7 7 0 1116.65 16.65z"/>
            </svg>
        </div>
    </div>
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-gray-100 text-left text-xs text-gray-400 uppercase tracking-wide">
                <th class="px-6 py-3 font-medium">Applicant</th>
                <th class="px-6 py-3 font-medium">Date Created</th>
                <th class="px-6 py-3 font-medium">Status</th>
                <th class="px-6 py-3 font-medium">Action</th>
            </tr>
        </thead>
        <tbody>
            {# Replace with real data loop later #}
            <tr>
                <td colspan="4" class="px-6 py-12 text-center">
                    <div class="flex flex-col items-center text-gray-400">
                        <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        <p class="text-sm font-medium">No applications found</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>
{% endblock %}
