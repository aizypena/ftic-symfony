{% extends 'admin/base.html.twig' %}

{% block title %}{{ title }} – FTIC Admin{% endblock %}

{% block body %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
        <p class="text-sm text-gray-500 mt-1">Fill in the details below</p>
    </div>
    <a href="{{ path('app_admin_users') }}"
       class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 px-4 py-2 rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Users
    </a>
</div>

{{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-6">

    {# Full Name #}
    <div>
        {{ form_label(form.fullName, 'Full Name', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.fullName, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50',
            placeholder: 'e.g. Juan dela Cruz'
        }}) }}
        {{ form_errors(form.fullName) }}
    </div>

    {# Email #}
    <div>
        {{ form_label(form.email, 'Email Address', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.email, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50',
            placeholder: 'user@example.com'
        }}) }}
        {{ form_errors(form.email) }}
    </div>

    {# Role #}
    <div>
        {{ form_label(form.role, 'Role', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.role, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50'
        }}) }}
        {{ form_errors(form.role) }}
    </div>

    {# Password #}
    <div>
        {{ form_label(form.plainPassword, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.plainPassword, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50'
        }}) }}
        {{ form_errors(form.plainPassword) }}
        {% if editUser is defined %}
            <p class="mt-1 text-xs text-gray-400">Leave blank to keep the current password.</p>
        {% endif %}
    </div>

</div>

<div class="flex items-center gap-4">
    <button type="submit"
            class="inline-flex items-center gap-2 text-sm font-semibold text-white px-6 py-2.5 rounded-lg shadow-sm transition"
            style="background-color:#0b3612;" onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Save User
    </button>
    <a href="{{ path('app_admin_users') }}" class="text-sm text-gray-500 hover:text-gray-700">Cancel</a>
</div>

{{ form_end(form) }}
{% endblock %}
