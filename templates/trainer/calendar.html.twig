{% extends 'trainer/base.html.twig' %}

{% block title %}Calendar – FTIC Trainer{% endblock %}

{% block body %}
{% set defaultCreateDate = '%04d-%02d-01'|format(currentYear, currentMonth) %}

<style>
:root {
    --cal-primary: #0b3612;
    --cal-primary-strong: #0f4a1a;
    --cal-ink: #111827;
    --cal-muted: #6b7280;
    --cal-border: #e5e7eb;
    --cal-bg: #f5f6f8;
    --cal-surface: #ffffff;
}

body {
    background: var(--cal-bg);
}

.calendar-shell {
    background: var(--cal-surface);
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.06);
    border: 1px solid #edf0f3;
}

.calendar-head {
    background: #f1f5f9;
    border-bottom: 1px solid #e2e8f0;
}

.crumb {
    font-size: 14px;
    color: var(--cal-muted);
    display: flex;
    align-items: center;
    gap: 6px;
}

.pill-group button {
    border-radius: 999px;
    border: 1px solid #d8dce2;
    padding: 8px 16px;
    font-weight: 700;
    color: var(--cal-muted);
    background: #fff;
}

.pill-group button.active {
    background: var(--cal-primary);
    border-color: var(--cal-primary);
    color: #fff;
    box-shadow: 0 10px 25px rgba(44, 126, 231, 0.28);
}

.nav-btn {
    border: 1px solid #d8dce2;
    background: #fff;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--cal-ink);
    transition: all 120ms ease;
}

.nav-btn:hover {
    background: #eef2f7;
}

.filter-btn {
    border: 1px solid #d8dce2;
    background: #fff;
    padding: 8px 14px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--cal-ink);
}

.cta-add {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 14px;
    border: 1px solid var(--cal-primary);
    color: var(--cal-primary);
    background: #f4f7ff;
    font-weight: 700;
}

.weekday-head {
    background: #e8f2ea;
    color: var(--cal-primary-strong);
    border-bottom: 1px solid #d1e0d3;
    font-weight: 700;
}

.calendar-grid {
    border-left: 1px solid var(--cal-border);
    border-right: 1px solid var(--cal-border);
    border-bottom: 1px solid var(--cal-border);
}

.calendar-day {
    border-right: 1px solid var(--cal-border);
    border-bottom: 1px solid var(--cal-border);
    background: #fff;
    transition: background 120ms ease;
    padding: 14px;
}

.calendar-day:hover,
.calendar-day:focus-within {
    background: #f9fbff;
}

.calendar-day .cal-add-btn {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.calendar-day:hover .cal-add-btn,
.calendar-day:focus-within .cal-add-btn {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
}

.calendar-event {
    border: 1px solid #dbeafe;
    background: #eef2ff;
    color: #1e3a8a;
}

.calendar-event:hover {
    background: #e0e7ff;
    border-color: #c7d2fe;
}

.month-scroll {
    max-height: 420px;
    overflow-y: auto;
}

.modal-shell {
    background: #fff;
    border-radius: 18px;
    padding: 28px;
    width: 100%;
    max-width: 580px;
    margin: 16px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
    max-height: calc(100vh - 32px);
    overflow: auto;
}
</style>

<div class="mb-6 space-y-4">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-3xl font-extrabold text-gray-900">Calendar</p>
            <div class="crumb mt-1">
                <span>Dashboard</span>
                <span>&rsaquo;</span>
                <span class="text-[var(--cal-ink)] font-semibold">Calendar</span>
            </div>
        </div>
    </div>

<div class="calendar-shell">
    <div class="calendar-head px-6 py-4 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-center gap-3">
            <button class="nav-btn" aria-label="Previous month" onclick="location.href='{{ path('app_trainer_calendar', {year: prevYear, month: prevMonth}) }}'">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <div class="text-2xl font-bold text-gray-900 mx-2">{{ monthLabel }}</div>
            <button class="nav-btn" aria-label="Next month" onclick="location.href='{{ path('app_trainer_calendar', {year: nextYear, month: nextMonth}) }}'">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </button>
            <a href="{{ path('app_trainer_calendar') }}" class="filter-btn ml-2">Today</a>
        </div>

        <div class="flex items-center gap-3">
            <div class="pill-group flex items-center gap-2">
                <button class="active" type="button">Month</button>
                <button type="button" class="cursor-not-allowed opacity-50">Week</button>
            </div>
            <button class="filter-btn" type="button">
                <span>All Events</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <button type="button" onclick="openCreateModal()" class="cta-add">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
                Add Event
            </button>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); text-align: center; font-size: 0.875rem;" class="weekday-head rounded-t-lg">
        {% for day in ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'] %}
            <div style="padding: 12px 0; border-right: 1px solid var(--cal-border);" class="last:border-r-0">{{ day }}</div>
        {% endfor %}
    </div>

    <div style="display: grid; grid-template-columns: repeat(7, minmax(0, 1fr));" class="calendar-grid bg-white">
        {% for day in days %}
            <button type="button"
                    onclick="openCreateModal('{{ day.dateKey }}')"
                    style="border-right: 1px solid var(--cal-border); border-bottom: 1px solid var(--cal-border); min-height: 140px;"
                    class="calendar-day group relative p-3 flex flex-col text-left cursor-pointer {{ day.inMonth ? '' : 'bg-gray-50 text-gray-400' }}">
                <div class="mb-2 relative w-full">
                    <span class="inline-flex items-center justify-center text-sm font-semibold {{ day.isToday ? 'w-8 h-8 rounded-full text-white bg-[var(--cal-primary)]' : (day.inMonth ? 'text-gray-700' : 'text-gray-400') }}">
                        {{ day.date|date('j') }}
                    </span>
                </div>

                <div onclick="event.stopPropagation(); openCreateModal('{{ day.dateKey }}')"
                     class="cal-add-btn absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white shadow text-[var(--cal-primary)] border border-gray-100 rounded-full flex items-center justify-center z-20 hover:scale-110 hover:shadow-md transition-all">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </div>

                <div class="space-y-1 overflow-hidden mt-1 w-full relative z-10 pointer-events-none">
                    {% for event in day.events|slice(0, 4) %}
                        {% set isWholeDay = (event.startsAt|date('H:i', false) == '00:00' and (not event.endsAt or event.endsAt|date('H:i', false) == '23:59')) %}
                        <div onclick="event.stopPropagation(); openModal('edit-shell-{{ event.id }}')"
                             class="w-full text-left rounded px-2 py-1 text-xs font-medium cursor-pointer pointer-events-auto border border-transparent hover:border-green-200 transition"
                             style="background-color: #e8f2ea; color: #0b3612; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {% if not isWholeDay %}
                                {{ event.startsAt|date('g:ia', false) }} 
                            {% endif %}
                            {{ event.title }}
                        </div>
                    {% endfor %}

                    {% if day.events|length > 4 %}
                        <p class="text-xs font-medium text-gray-500 px-1 hover:text-gray-800 transition pointer-events-auto">{{ day.events|length - 4 }} more</p>
                    {% endif %}
                </div>
            </button>
        {% endfor %}
    </div>
</div>
</div>


<div id="create-event-modal"
     style="display:none; position:fixed; inset:0; z-index:999; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;"
     onclick="if(event.target===this) closeModal('create-event-modal')">
    <div class="modal-shell">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
            <h3 style="font-size:16px; font-weight:700; color:#111827; margin:0;">Add Event</h3>
            <button type="button" onclick="closeModal('create-event-modal')"
                    style="width:32px; height:32px; border-radius:8px; border:none; background:#f3f4f6; cursor:pointer; display:flex; align-items:center; justify-content:center; color:#6b7280;"
                    onmouseover="this.style.background='#e5e7eb'" onmouseout="this.style.background='#f3f4f6'">
                <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" action="{{ path('app_trainer_calendar_event_create') }}" class="space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('trainer-event-create') }}">
            <input type="hidden" name="year" value="{{ currentYear }}">
            <input type="hidden" name="month" value="{{ currentMonth }}">

            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Title</label>
                <input type="text" name="title" required maxlength="255"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2"
                       placeholder="Ex. Live session with BSIT 2A">
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Date</label>
                    <input type="date" name="event_date" id="create-event-date" value="{{ defaultCreateDate }}" required
                           class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                </div>
                <div class="col-span-2 flex items-center">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" id="create-whole-day" checked
                               class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500"
                               onchange="toggleTimeInputs('create', this.checked)">
                        <span class="ml-2 text-sm text-gray-700">Whole day event</span>
                    </label>
                </div>
                <div class="create-time-inputs hidden col-span-1">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Start</label>
                    <input type="time" name="start_time" id="create-start-time"
                           class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                </div>
                <div class="create-time-inputs hidden col-span-1">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">End</label>
                    <input type="time" name="end_time" id="create-end-time"
                           class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Notes</label>
                <textarea name="description" rows="4"
                          class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 resize-none"
                          placeholder="Optional details for this event"></textarea>
            </div>

            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeModal('create-event-modal')"
                        class="px-4 py-2 text-sm font-semibold rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition">
                    Cancel
                </button>
                <button type="submit"
                        class="px-4 py-2 text-sm font-semibold rounded-lg text-white transition"
                        style="background-color:#0b3612;"
                        onmouseover="this.style.backgroundColor='#5c8d67'"
                        onmouseout="this.style.backgroundColor='#0b3612'">
                    Save Event
                </button>
            </div>
        </form>
    </div>
</div>

{% for event in monthEvents %}
    <div id="edit-shell-{{ event.id }}"
         style="display:none; position:fixed; inset:0; z-index:999; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;"
         onclick="if(event.target===this) closeModal('edit-shell-{{ event.id }}')">
        <div class="modal-shell">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <h3 style="font-size:16px; font-weight:700; color:#111827; margin:0;">Edit Event</h3>
                <button type="button" onclick="closeModal('edit-shell-{{ event.id }}')"
                        style="width:32px; height:32px; border-radius:8px; border:none; background:#f3f4f6; cursor:pointer; display:flex; align-items:center; justify-content:center; color:#6b7280;"
                        onmouseover="this.style.background='#e5e7eb'" onmouseout="this.style.background='#f3f4f6'">
                    <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <form method="post" action="{{ path('app_trainer_calendar_event_edit', {id: event.id}) }}" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('trainer-event-edit-' ~ event.id) }}">
                <input type="hidden" name="year" value="{{ currentYear }}">
                <input type="hidden" name="month" value="{{ currentMonth }}">

                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Title</label>
                    <input type="text" name="title" required maxlength="255" value="{{ event.title }}"
                           class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Date</label>
                        <input type="date" name="event_date" required value="{{ event.startsAt|date('Y-m-d', false) }}"
                               class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                    </div>
                    {% set isWholeDayEvent = (event.startsAt|date('H:i', false) == '00:00' and event.endsAt and event.endsAt|date('H:i', false) == '23:59') %}
                    <div class="col-span-2 flex items-center">
                        <label class="flex items-center cursor-pointer">
                            <input type="checkbox" id="edit-whole-day-{{ event.id }}" {{ isWholeDayEvent ? 'checked' : '' }}
                                   class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500"
                                   onchange="toggleTimeInputs('edit-{{ event.id }}', this.checked)">
                            <span class="ml-2 text-sm text-gray-700">Whole day event</span>
                        </label>
                    </div>
                    <div class="edit-{{ event.id }}-time-inputs {{ isWholeDayEvent ? 'hidden' : '' }} col-span-1">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Start</label>
                        <input type="time" name="start_time" id="edit-start-{{ event.id }}" value="{{ isWholeDayEvent ? '' : event.startsAt|date('H:i', false) }}"
                               class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                    </div>
                    <div class="edit-{{ event.id }}-time-inputs {{ isWholeDayEvent ? 'hidden' : '' }} col-span-1">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">End</label>
                        <input type="time" name="end_time" id="edit-end-{{ event.id }}" value="{{ isWholeDayEvent ? '' : (event.endsAt ? event.endsAt|date('H:i', false) : '') }}"
                               class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Notes</label>
                    <textarea name="description" rows="4"
                              class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 resize-none">{{ event.description }}</textarea>
                </div>

                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" onclick="closeModal('edit-shell-{{ event.id }}')"
                            class="px-4 py-2 text-sm font-semibold rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button type="submit"
                            class="px-4 py-2 text-sm font-semibold rounded-lg text-white transition"
                            style="background-color:#0b3612;"
                            onmouseover="this.style.backgroundColor='#5c8d67'"
                            onmouseout="this.style.backgroundColor='#0b3612'">
                        Save Changes
                    </button>
                </div>
            </form>

            <form method="post" action="{{ path('app_trainer_calendar_event_delete', {id: event.id}) }}" class="mt-3 pt-3 border-t border-gray-100">
                <input type="hidden" name="_token" value="{{ csrf_token('trainer-event-delete-' ~ event.id) }}">
                <input type="hidden" name="year" value="{{ currentYear }}">
                <input type="hidden" name="month" value="{{ currentMonth }}">
                <button type="submit"
                        class="w-full px-4 py-2 text-sm font-semibold rounded-lg bg-red-50 text-red-600 hover:bg-red-100 transition">
                    Delete Event
                </button>
            </form>
        </div>
    </div>
{% endfor %}

<script>
function openModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
}

function openCreateModal(dateValue) {
    if (dateValue) {
        document.getElementById('create-event-date').value = dateValue;
    }
    // Default to whole day for new events
    var wholeDayCheckbox = document.getElementById('create-whole-day');
    if (wholeDayCheckbox) {
        wholeDayCheckbox.checked = true;
        toggleTimeInputs('create', true);
    }
    document.getElementById('create-start-time').value = '';
    document.getElementById('create-end-time').value = '';
    openModal('create-event-modal');
}

function toggleTimeInputs(prefix, isWholeDay) {
    var inputs = document.querySelectorAll('.' + prefix + '-time-inputs');
    inputs.forEach(function(el) {
        if (isWholeDay) {
            el.classList.add('hidden');
        } else {
            el.classList.remove('hidden');
        }
    });
}

document.addEventListener('keydown', function(event) {
    if (event.key !== 'Escape') return;
    document.querySelectorAll('[id$="-modal"], [id^="edit-shell-"]').forEach(function(modal) {
        if (modal.style.display === 'flex') {
            modal.style.display = 'none';
        }
    });
    document.body.style.overflow = '';
});
</script>
{% endblock %}
