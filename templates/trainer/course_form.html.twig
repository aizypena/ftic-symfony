{% extends 'trainer/base.html.twig' %}

{% block title %}{{ title }} – FTIC Trainer{% endblock %}

{% block body %}
<div class="mb-6 flex items-center justify-between flex-wrap gap-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
        <p class="text-sm text-gray-500 mt-1">Provide the basic details for your new course</p>
    </div>
    <a href="{{ path('app_trainer_courses') }}"
       class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 px-4 py-2 rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Courses
    </a>
</div>

{% if activeTerm %}
    <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-lg border border-green-200 bg-green-50 text-sm text-green-800">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <p>Your course will be attached to <span class="font-semibold">{{ activeTerm.displayLabel ? activeTerm.displayLabel : activeTerm.schoolYear ~ ' - ' ~ activeTerm.termLabel }}</span> ({{ activeTerm.startDate|date('M d, Y') }} - {{ activeTerm.endDate|date('M d, Y') }}).</p>
    </div>
{% else %}
    <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-lg border border-yellow-200 bg-yellow-50 text-sm text-yellow-800">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p>No active academic term is currently set. Please contact the administrator before creating a course.</p>
    </div>
{% endif %}

{{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-6">
    <div>
        {{ form_label(form.name, 'Course Name', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.name, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50',
            placeholder: 'e.g. First Aid Essentials'
        }}) }}
        {{ form_errors(form.name) }}
    </div>

    <div>
        {{ form_label(form.description, 'Description', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.description, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50 resize-none',
            rows: 4,
            placeholder: 'Briefly describe what this course will cover...'
        }}) }}
        {{ form_errors(form.description) }}
    </div>

    <div>
        {{ form_label(form.status, 'Status', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.status, {attr: {
            class: 'w-full px-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 bg-gray-50'
        }}) }}
        {{ form_errors(form.status) }}
    </div>
</div>

<div class="flex items-center gap-4">
    <button type="submit"
            class="inline-flex items-center gap-2 text-sm font-semibold text-white px-6 py-2.5 rounded-lg shadow-sm transition{{ activeTerm ? '' : ' opacity-60 cursor-not-allowed' }}"
            style="background-color:#0b3612;"
            {% if activeTerm %}
                onmouseover="this.style.backgroundColor='#5c8d67'"
                onmouseout="this.style.backgroundColor='#0b3612'"
            {% endif %}
            {% if not activeTerm %}disabled{% endif %}>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Save Course
    </button>
    <a href="{{ path('app_trainer_courses') }}" class="text-sm text-gray-500 hover:text-gray-700">Cancel</a>
</div>

{{ form_end(form) }}
{% endblock %}
