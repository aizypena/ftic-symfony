{% extends 'base.html.twig' %}

{% block title %}Trainer Dashboard – FTIC{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Trainer Dashboard</h1>
            <p class="text-gray-500 mt-1">Welcome back, <span class="font-medium text-feu-light">{{ user.displayName }}</span></p>
        </div>
        <span class="inline-flex items-center gap-1.5 bg-feu-pale text-feu-dark text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/></svg>
            Trainer
        </span>
    </div>

    {# Stats #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">My Courses</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Active courses</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">My Students</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Enrolled in your courses</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Pending Reviews</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
            <p class="text-xs text-gray-400 mt-1">Submissions to grade</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Date</p>
            <p class="text-xl font-bold text-gray-900">{{ "now"|date("M d, Y") }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Trainer Actions #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-4">Quick Actions</h2>
            <ul class="space-y-2">
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                    Create Course
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    View Students
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Grade Submissions
                </a></li>
                <li><a href="#" class="flex items-center gap-3 text-sm text-gray-700 hover:text-feu-dark hover:bg-feu-pale rounded-lg px-3 py-2.5 transition group">
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Progress Reports
                </a></li>
            </ul>
        </div>

        {# My Courses #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 lg:col-span-2">
            <h2 class="text-base font-semibold text-gray-900 mb-4">My Courses</h2>
            <div class="flex flex-col items-center justify-center py-12 text-center text-gray-400">
                <svg class="w-14 h-14 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                <p class="text-sm font-medium text-gray-500">No courses yet</p>
                <p class="text-xs text-gray-400 mt-1">Create your first course to get started</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
