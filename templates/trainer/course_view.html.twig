{% extends 'trainer/base.html.twig' %}

{% block title %}{{ course.name }} – FTIC Trainer{% endblock %}

{% block body %}

{# ── Header ── #}
<div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
        <a href="{{ path('app_trainer_courses') }}" class="inline-flex items-center gap-1 text-xs text-gray-400 hover:text-gray-600 mb-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Courses
        </a>
        <h1 class="text-2xl font-bold text-gray-900">{{ course.name }}</h1>
        {% if course.description %}
            <p class="text-sm text-gray-500 mt-1">{{ course.description }}</p>
        {% endif %}
    </div>
    <div class="flex items-center gap-3 shrink-0">
        <span class="text-xs font-semibold px-3 py-1 rounded-full"
              style="{% if course.status == 'active' %}background-color:#e8f2ea;color:#0b3612;{% else %}background-color:#f3f4f6;color:#6b7280;{% endif %}">
            {{ course.status|capitalize }}
        </span>
        <form method="post" action="{{ path('app_trainer_course_toggle', {id: course.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('toggle-' ~ course.id) }}">
            <button type="submit"
                    class="text-xs font-semibold px-4 py-2 rounded-lg text-white transition"
                    style="background-color:#0b3612;"
                    onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
                Mark {{ course.status == 'active' ? 'Inactive' : 'Active' }}
            </button>
        </form>
    </div>
</div>

{% for msg in app.flashes('success') %}
    <div class="mb-4 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-3">{{ msg }}</div>
{% endfor %}

{# ── Upload Panel ── #}
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Upload PDF to a Week</h2>
    {{ form_start(uploadForm, {attr: {enctype: 'multipart/form-data', id: 'upload-form', novalidate: 'novalidate'}}) }}
    {{ form_errors(uploadForm) }}

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
        {# Week selector #}
        <div>
            <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Target Week</label>
            <select name="week_number"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none"
                    style="focus:ring:2px solid #5c8d67;">
                {% for w in 1..14 %}
                    <option value="{{ w }}">
                        Week {{ w }}{% if weeks[w] is defined and weeks[w].title != 'Week ' ~ w %} – {{ weeks[w].title }}{% endif %}
                    </option>
                {% endfor %}
            </select>
        </div>

        {# File drop zone #}
        <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Select PDF File</label>
            <div id="drop-zone"
                 onclick="document.getElementById('upload-form').querySelector('input[type=file]').click()"
                 ondragover="event.preventDefault();this.style.borderColor='#5c8d67';this.style.background='#f0f7f1';"
                 ondragleave="if(!this.dataset.selected){this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';}"
                 ondrop="handleFileDrop(event)"
                 style="border:2px dashed #e5e7eb;border-radius:10px;padding:20px 16px;text-align:center;cursor:pointer;background:#f9fafb;transition:border-color .2s,background .2s;">
                <div id="dz-placeholder">
                    <svg style="width:2rem;height:2rem;margin:0 auto 6px;color:#d1d5db;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                    </svg>
                    <p style="font-size:13px;color:#9ca3af;">Click to browse or drag a PDF here</p>
                    <p style="font-size:11px;color:#d1d5db;margin-top:2px;">Max 50 MB • PDF only</p>
                </div>
                <div id="dz-selected" style="display:none;">
                    <svg style="width:2rem;height:2rem;margin:0 auto 6px;color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <p id="dz-filename" style="font-size:13px;font-weight:600;color:#0b3612;"></p>
                    <p id="dz-filesize" style="font-size:11px;color:#5c8d67;margin-top:2px;"></p>
                    <p style="font-size:11px;color:#9ca3af;margin-top:4px;">Click to change file</p>
                </div>
            </div>
            <div style="display:none;">{{ form_widget(uploadForm.file, {attr: {accept: '.pdf,application/pdf'}}) }}</div>
            {{ form_errors(uploadForm.file) }}
        </div>
    </div>

    <button type="submit"
            class="mt-4 text-sm font-semibold text-white px-6 py-2.5 rounded-lg transition"
            style="background-color:#0b3612;"
            onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
        Upload PDF
    </button>
    {{ form_end(uploadForm) }}
</div>

{# ── Weeks Accordion ── #}
<div class="space-y-2">
    {% for weekNum, week in weeks %}
    <div id="week-{{ weekNum }}" class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

        {# Week toggle button #}
        <button type="button"
                onclick="toggleWeek({{ weekNum }})"
                class="w-full flex items-center justify-between px-6 py-4 text-left hover:bg-gray-50 transition">
            <div class="flex items-center gap-3">
                <span class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-bold text-white shrink-0"
                      style="background-color:#0b3612;">{{ weekNum }}</span>
                <div class="text-left">
                    <p class="text-sm font-semibold text-gray-900">{{ week.title }}</p>
                    {% if week.description %}
                        <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{{ week.description }}</p>
                    {% endif %}
                </div>
            </div>
            <div class="flex items-center gap-3 shrink-0">
                <span class="text-xs px-2 py-0.5 rounded-full"
                      style="{% if week.materials|length > 0 %}background-color:#e8f2ea;color:#0b3612;{% else %}background:#f3f4f6;color:#9ca3af;{% endif %}">
                    {{ week.materials|length }} PDF{{ week.materials|length != 1 ? 's' : '' }}
                </span>
                <svg id="chevron-{{ weekNum }}" class="w-4 h-4 text-gray-400 transition-transform duration-200"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </div>
        </button>

        {# Week body #}
        <div id="week-body-{{ weekNum }}" style="display:none;" class="border-t border-gray-50">
            <div class="px-6 py-5">

                {# Edit week info #}
                <details class="mb-4 group">
                    <summary class="text-xs font-medium cursor-pointer select-none list-none flex items-center gap-1"
                             style="color:#5c8d67;">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit week title &amp; description
                    </summary>
                    <form method="post" action="{{ path('app_trainer_week_update', {id: week.id}) }}"
                          class="mt-3 space-y-2 p-4 rounded-lg" style="background:#f8faf8;">
                        <input type="hidden" name="_token" value="{{ csrf_token('week-update-' ~ week.id) }}">
                        <input type="text" name="title" value="{{ week.title }}"
                               placeholder="Week title"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2"
                               style="--tw-ring-color:#5c8d67;">
                        <textarea name="description" rows="2"
                                  placeholder="Optional description for this week…"
                                  class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none resize-none">{{ week.description }}</textarea>
                        <button type="submit"
                                class="text-xs font-semibold px-4 py-1.5 rounded-lg text-white"
                                style="background-color:#5c8d67;">Save Changes</button>
                    </form>
                </details>

                {# PDF list for this week #}
                {% if week.materials|length > 0 %}
                <ul class="space-y-2">
                    {% for material in week.materials %}
                    <li class="flex items-center justify-between p-3 rounded-lg gap-4" style="background:#f8faf8;">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                 style="background-color:#e8f2ea;">
                                <svg class="w-4 h-4" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-gray-800 truncate">{{ material.originalName }}</p>
                                <p class="text-xs text-gray-400">{{ material.uploadedAt|date('M d, Y') }}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <a href="{{ asset('uploads/materials/' ~ material.filename) }}" target="_blank"
                               class="text-xs font-semibold px-3 py-1.5 rounded-lg text-white"
                               style="background-color:#5c8d67;">View</a>
                            <form method="post"
                                  action="{{ path('app_trainer_material_delete', {id: material.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-material-' ~ material.id) }}">
                                <button type="button"
                                        onclick="openConfirmModal(this.closest('form'), 'This will permanently delete &quot;{{ material.originalName|e('html_attr') }}&quot;. This action cannot be undone.', 'Delete PDF')"
                                        class="text-xs font-semibold px-3 py-1.5 rounded-lg text-white bg-red-500 hover:bg-red-600 transition">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p class="text-sm text-gray-400 py-2 text-center">No PDFs uploaded for this week yet.</p>
                {% endif %}

            </div>
        </div>
    </div>
    {% endfor %}
</div>

<script>
(function () {
    const form  = document.getElementById('upload-form');
    if (!form) return;
    const input = form.querySelector('input[type="file"]');
    if (!input) return;

    const dz         = document.getElementById('drop-zone');
    const placeholder = document.getElementById('dz-placeholder');
    const selected   = document.getElementById('dz-selected');
    const fname      = document.getElementById('dz-filename');
    const fsize      = document.getElementById('dz-filesize');

    function showFile(file) {
        placeholder.style.display = 'none';
        selected.style.display    = 'block';
        dz.style.borderColor      = '#5c8d67';
        dz.style.background       = '#f0f7f1';
        dz.dataset.selected       = '1';
        fname.textContent = file.name;
        fsize.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
    }

    input.addEventListener('change', function () {
        if (this.files && this.files[0]) showFile(this.files[0]);
    });

    window.handleFileDrop = function (e) {
        e.preventDefault();
        const file = e.dataTransfer.files[0];
        if (!file) return;
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        showFile(file);
    };
})();

function toggleWeek(n) {
    const body    = document.getElementById('week-body-' + n);
    const chevron = document.getElementById('chevron-' + n);
    const isOpen  = body.style.display !== 'none';
    body.style.display      = isOpen ? 'none' : 'block';
    chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
}

// Auto-open from URL hash (e.g. #week-3 after upload redirect)
(function () {
    const hash = window.location.hash;
    if (hash && hash.startsWith('#week-')) {
        const n = parseInt(hash.replace('#week-', ''));
        if (!isNaN(n)) {
            toggleWeek(n);
            setTimeout(function () {
                document.getElementById('week-' + n)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }
    }
})();
</script>
{% endblock %}
