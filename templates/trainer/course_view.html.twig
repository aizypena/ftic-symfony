{% extends 'trainer/base.html.twig' %}

{% block title %}{{ course.name }} – FTIC Trainer{% endblock %}

{% block body %}
{# Header #}
<div class="mb-6 flex items-start justify-between gap-4">
    <div>
        <a href="{{ path('app_trainer_courses') }}" class="inline-flex items-center gap-1 text-xs text-gray-400 hover:text-gray-600 mb-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Courses
        </a>
        <h1 class="text-2xl font-bold text-gray-900">{{ course.name }}</h1>
        {% if course.description %}
            <p class="text-sm text-gray-500 mt-1">{{ course.description }}</p>
        {% endif %}
    </div>
    {# Status Toggle #}
    <form method="post" action="{{ path('app_trainer_course_toggle', {id: course.id}) }}" class="shrink-0">
        <input type="hidden" name="_token" value="{{ csrf_token('toggle-' ~ course.id) }}">
        <button type="submit"
                class="inline-flex items-center gap-2 text-xs font-semibold px-4 py-2 rounded-lg border transition {% if course.status == 'active' %}border-green-200 text-green-700 bg-green-50 hover:bg-green-100{% else %}border-gray-200 text-gray-500 bg-gray-50 hover:bg-gray-100{% endif %}">
            <span class="w-2 h-2 rounded-full inline-block {% if course.status == 'active' %}bg-green-500{% else %}bg-gray-400{% endif %}"></span>
            {% if course.status == 'active' %}Active — click to deactivate{% else %}Inactive — click to activate{% endif %}
        </button>
    </form>
</div>

{% for message in app.flashes('success') %}
    <div class="mb-4 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-3">{{ message }}</div>
{% endfor %}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# ── PDF List ── #}
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900">Course Materials</h2>
            <span class="text-xs text-gray-400">{{ course.materials|length }} PDF{{ course.materials|length != 1 ? 's' : '' }}</span>
        </div>

        {% if course.materials|length == 0 %}
        <div class="px-6 py-12 flex flex-col items-center text-gray-400">
            <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <p class="text-sm font-medium">No PDFs uploaded yet</p>
            <p class="text-xs mt-1">Use the upload form to add course materials.</p>
        </div>
        {% else %}
        <ul class="divide-y divide-gray-50">
            {% for material in course.materials %}
            <li class="px-6 py-4 flex items-center justify-between gap-4">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background-color:#e8f2ea;">
                        <svg class="w-5 h-5" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-medium text-gray-900 truncate">{{ material.originalName }}</p>
                        <p class="text-xs text-gray-400">Uploaded {{ material.uploadedAt|date('M d, Y') }}</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                    <a href="{{ asset('uploads/materials/' ~ material.filename) }}" target="_blank"
                       class="text-xs font-medium hover:underline" style="color:#0b3612;">View</a>
                    <form method="post" action="{{ path('app_trainer_material_delete', {id: material.id}) }}"
                          onsubmit="return confirm('Delete this PDF?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-material-' ~ material.id) }}">
                        <button type="submit" class="text-xs font-medium text-red-500 hover:underline">Delete</button>
                    </form>
                </div>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
    </div>

    {# ── Upload Form ── #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 h-fit">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Upload PDF</h2>
        {{ form_start(uploadForm, {attr: {enctype: 'multipart/form-data', class: 'space-y-4', novalidate: 'novalidate'}}) }}

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Select PDF File</label>

            {# Hide the real input, render it outside the visual area #}
            <div style="display:none;">
                {{ form_widget(uploadForm.file, {attr: {accept: '.pdf,application/pdf'}}) }}
            </div>

            {# Clickable drop zone #}
            <div id="drop-zone"
                 onclick="this.closest('form').querySelector('input[type=file]').click()"
                 style="display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;min-height:9rem;border:2px dashed #e5e7eb;border-radius:0.5rem;cursor:pointer;background:#f9fafb;transition:all 0.2s;"
                 onmouseover="if(!this.dataset.selected){this.style.borderColor='#d1d5db';this.style.background='#f3f4f6';}"
                 onmouseout="if(!this.dataset.selected){this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';}">

                {# Default state #}
                <div id="upload-default" style="display:flex;flex-direction:column;align-items:center;">
                    <svg style="width:2rem;height:2rem;color:#d1d5db;margin-bottom:0.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                    </svg>
                    <span style="font-size:0.75rem;color:#9ca3af;">Click to browse or drag a PDF here</span>
                    <span style="font-size:0.75rem;color:#d1d5db;margin-top:0.25rem;">Max 50 MB</span>
                </div>

                {# Selected state #}
                <div id="upload-selected" style="display:none;flex-direction:column;align-items:center;">
                    <svg style="width:2rem;height:2rem;color:#0b3612;margin-bottom:0.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    <span id="file-name" style="font-size:0.75rem;font-weight:600;color:#111827;text-align:center;padding:0 0.5rem;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
                    <span id="file-size" style="font-size:0.75rem;color:#9ca3af;margin-top:0.125rem;"></span>
                    <span style="font-size:0.75rem;color:#5c8d67;margin-top:0.25rem;">✓ Ready to upload — click to change</span>
                </div>
            </div>

            {{ form_errors(uploadForm) }}
            {{ form_errors(uploadForm.file) }}
        </div>

        <button type="submit"
                class="w-full text-sm font-semibold text-white py-2.5 rounded-lg transition"
                style="background-color:#0b3612;" onmouseover="this.style.backgroundColor='#5c8d67'" onmouseout="this.style.backgroundColor='#0b3612'">
            Upload PDF
        </button>
        {{ form_end(uploadForm) }}
    </div>

</div>

<script>
(function () {
    const form = document.querySelector('form[enctype="multipart/form-data"]');
    if (!form) return;
    const input = form.querySelector('input[type="file"]');
    if (!input) return;

    const dropZone = document.getElementById('drop-zone');
    const defaultState = document.getElementById('upload-default');
    const selectedState = document.getElementById('upload-selected');
    const fileNameEl = document.getElementById('file-name');
    const fileSizeEl = document.getElementById('file-size');

    input.addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const file = this.files[0];
            const sizeMB = (file.size / (1024 * 1024)).toFixed(2);

            fileNameEl.textContent = file.name;
            fileSizeEl.textContent = sizeMB + ' MB';

            defaultState.style.display = 'none';
            selectedState.style.display = 'flex';
            dropZone.style.borderColor = '#5c8d67';
            dropZone.style.background = '#f0f7f1';
            dropZone.dataset.selected = '1';
        } else {
            defaultState.style.display = 'flex';
            selectedState.style.display = 'none';
            dropZone.style.borderColor = '#e5e7eb';
            dropZone.style.background = '#f9fafb';
            delete dropZone.dataset.selected;
        }
    });
})();
</script>
{% endblock %}
