{% extends 'trainer/base.html.twig' %}

{% block title %}Submissions – FTIC Trainer{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Submissions</h1>
    <p class="text-sm text-gray-500 mt-1">Review student submissions</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900">Submission List</h2>
        <div class="flex gap-2">
            <span class="text-xs font-medium px-3 py-1 rounded-full cursor-pointer" style="background-color:#e8f2ea;color:#0b3612;">All</span>
            <span class="text-xs font-medium px-3 py-1 rounded-full cursor-pointer text-gray-500 bg-gray-100 hover:bg-gray-200">Pending</span>
            <span class="text-xs font-medium px-3 py-1 rounded-full cursor-pointer text-gray-500 bg-gray-100 hover:bg-gray-200">Graded</span>
        </div>
    </div>
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-gray-100 text-left text-xs text-gray-400 uppercase tracking-wide">
                <th class="px-6 py-3 font-medium">Student</th>
                <th class="px-6 py-3 font-medium">Course</th>
                <th class="px-6 py-3 font-medium">Submitted</th>
                <th class="px-6 py-3 font-medium">Status</th>
                <th class="px-6 py-3 font-medium">Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="5" class="px-6 py-12 text-center">
                    <div class="flex flex-col items-center text-gray-400">
                        <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <p class="text-sm font-medium">No submissions yet</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>
{% endblock %}
