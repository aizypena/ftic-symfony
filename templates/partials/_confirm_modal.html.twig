{# ── Reusable Delete Confirmation Modal ──────────────────────────────────────
   Usage: call window.openConfirmModal(formElement, message, title?)
   Example button:
       <button type="button"
               onclick="openConfirmModal(this.closest('form'), 'Are you sure you want to delete this item?')">
           Delete
       </button>
   The form itself needs no onsubmit handler.
────────────────────────────────────────────────────────────────────────────── #}

{# Backdrop #}
<div id="confirm-modal-backdrop"
     onclick="closeConfirmModal()"
     style="
         display:none;
         position:fixed;
         inset:0;
         background:rgba(0,0,0,0.45);
         z-index:10000;
         transition:opacity 0.2s ease;
         opacity:0;
     ">
</div>

{# Modal card #}
<div id="confirm-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="confirm-modal-title"
     style="
         display:none;
         position:fixed;
         top:50%;
         left:50%;
         transform:translate(-50%, -48%) scale(0.96);
         z-index:10001;
         background:#fff;
         border-radius:14px;
         box-shadow:0 20px 60px rgba(0,0,0,0.18);
         width:100%;
         max-width:420px;
         padding:28px 28px 24px;
         transition:transform 0.2s ease, opacity 0.2s ease;
         opacity:0;
     ">

    {# Icon + Title #}
    <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;">
        <div style="
            flex-shrink:0;
            width:42px;height:42px;
            border-radius:50%;
            background:#fef2f2;
            display:flex;align-items:center;justify-content:center;
        ">
            <svg style="width:20px;height:20px;stroke:#dc2626;" fill="none" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
        </div>
        <div>
            <p id="confirm-modal-title" style="font-size:15px;font-weight:700;color:#111827;margin:0 0 4px;">
                Confirm Delete
            </p>
            <p id="confirm-modal-message" style="font-size:13.5px;color:#6b7280;margin:0;line-height:1.5;">
                Are you sure you want to delete this? This action cannot be undone.
            </p>
        </div>
    </div>

    {# Divider #}
    <div style="border-top:1px solid #f3f4f6;margin:18px 0;"></div>

    {# Buttons #}
    <div style="display:flex;justify-content:flex-end;gap:10px;">
        <button type="button"
                onclick="closeConfirmModal()"
                style="
                    padding:9px 18px;
                    font-size:13.5px;
                    font-weight:600;
                    border-radius:8px;
                    border:1px solid #e5e7eb;
                    background:#fff;
                    color:#374151;
                    cursor:pointer;
                    transition:background 0.15s;
                "
                onmouseover="this.style.background='#f9fafb'"
                onmouseout="this.style.background='#fff'">
            Cancel
        </button>
        <button type="button"
                id="confirm-modal-delete-btn"
                onclick="confirmDelete()"
                style="
                    padding:9px 18px;
                    font-size:13.5px;
                    font-weight:600;
                    border-radius:8px;
                    border:none;
                    background:#dc2626;
                    color:#fff;
                    cursor:pointer;
                    transition:background 0.15s;
                "
                onmouseover="this.style.background='#b91c1c'"
                onmouseout="this.style.background='#dc2626'">
            Delete
        </button>
    </div>
</div>

<script>
(function () {
    var _pendingForm = null;

    window.openConfirmModal = function (formEl, message, title) {
        _pendingForm = formEl;

        var titleEl   = document.getElementById('confirm-modal-title');
        var messageEl = document.getElementById('confirm-modal-message');
        var backdrop  = document.getElementById('confirm-modal-backdrop');
        var modal     = document.getElementById('confirm-modal');

        if (title)   titleEl.textContent   = title;
        if (message) messageEl.textContent = message;

        // Show
        backdrop.style.display = 'block';
        modal.style.display    = 'block';

        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                backdrop.style.opacity = '1';
                modal.style.opacity    = '1';
                modal.style.transform  = 'translate(-50%, -50%) scale(1)';
            });
        });

        // Trap focus on delete button
        document.getElementById('confirm-modal-delete-btn').focus();
    };

    window.closeConfirmModal = function () {
        var backdrop = document.getElementById('confirm-modal-backdrop');
        var modal    = document.getElementById('confirm-modal');

        backdrop.style.opacity = '0';
        modal.style.opacity    = '0';
        modal.style.transform  = 'translate(-50%, -48%) scale(0.96)';

        setTimeout(function () {
            backdrop.style.display = 'none';
            modal.style.display    = 'none';
            _pendingForm = null;
        }, 200);
    };

    window.confirmDelete = function () {
        if (_pendingForm) {
            _pendingForm.submit();
        }
        closeConfirmModal();
    };

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeConfirmModal();
    });
})();
</script>
