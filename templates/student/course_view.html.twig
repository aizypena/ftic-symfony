{% extends 'student/base.html.twig' %}

{% block title %}{{ course.name }} – FTIC Student{% endblock %}

{% block body %}

{% set totalSubmissions = 0 %}
{% for items in submissionsByWeek %}
    {% set totalSubmissions = totalSubmissions + (items|length) %}
{% endfor %}

<section class="mb-8 space-y-6">
    <div class="relative overflow-hidden rounded-3xl hero-banner hero-banner--student px-6 py-7 text-white shadow-xl">
        <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.3), transparent 45%), radial-gradient(circle at 80% 0%, rgba(255,255,255,0.25), transparent 50%);"></div>
        <div class="relative flex flex-wrap items-start justify-between gap-6">
            <div class="space-y-3 max-w-3xl">
                <a href="{{ path('app_student_courses') }}" class="inline-flex items-center gap-1 text-xs text-emerald-100/80 hover:text-white transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back to My Courses
                </a>
                <div class="space-y-1">
                    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-white/70">Course Journey</p>
                    <h1 class="text-3xl font-semibold leading-tight">{{ course.name }}</h1>
                </div>
                {% if course.description %}
                    <p class="text-sm text-white/80">{{ course.description }}</p>
                {% endif %}
            </div>
            <div class="flex flex-col items-end gap-3 text-sm text-white/80">
                <span class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-semibold shadow-sm"
                      style="background-color:rgba(255,255,255,0.15);">
                    <span class="h-1.5 w-1.5 rounded-full" style="background-color:{% if course.status == 'active' %}#bbf7d0{% else %}#fee2e2{% endif %};"></span>
                    {{ course.status|capitalize }}
                </span>
                {% if course.trainer %}
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-base font-semibold text-white">
                            {{ course.trainer.displayName|first|upper }}
                        </div>
                        <div class="text-right">
                            <p class="text-xs uppercase tracking-[0.25em] text-white/60">Trainer</p>
                            <p class="text-sm font-semibold text-white">{{ course.trainer.displayName }}</p>
                        </div>
                    </div>
                {% endif %}
                {% if course.term %}
                    <div class="text-right">
                        <p class="text-xs uppercase tracking-[0.25em] text-white/60">Academic Window</p>
                        <p class="text-sm font-semibold text-white">{{ course.term.schoolYear }} · {{ course.term.termLabel }}</p>
                        <p class="text-xs text-white/70">{{ course.term.startDate|date('M d, Y') }} – {{ course.term.endDate|date('M d, Y') }}</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="h-10 w-10 rounded-2xl bg-emerald-50 text-emerald-700 flex items-center justify-center text-lg font-semibold">{{ weeks|length }}</div>
                <div>
                    <p class="text-xs uppercase tracking-[0.35em] text-gray-400">Weekly cadence</p>
                    <p class="text-sm font-semibold text-gray-800">14 scheduled weeks of content</p>
                </div>
            </div>
            <div class="hidden h-10 w-px bg-gray-200 md:block"></div>
            <div class="flex items-center gap-3">
                <div class="h-10 w-10 rounded-2xl bg-slate-50 text-slate-700 flex items-center justify-center text-lg font-semibold">
                    {{ totalSubmissions }}
                </div>
                <div>
                    <p class="text-xs uppercase tracking-[0.35em] text-gray-400">Your uploads</p>
                    <p class="text-sm font-semibold text-gray-800">Track submitted assignments per week</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Weekly Materials Accordion ── #}
<section class="space-y-4">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-xs uppercase tracking-[0.4em] text-gray-400">Weekly drops</p>
            <h2 class="text-lg font-semibold text-gray-900">Resources, announcements, and submissions</h2>
        </div>
        <p class="text-xs text-gray-400">Tap a week to expand details</p>
    </div>
    <div class="space-y-3">
{% for w in 1..14 %}
    {% set week = weeks[w] is defined ? weeks[w] : null %}
    {% set hasMaterials = week and week.materials|length > 0 %}

    <div class="rounded-2xl border border-gray-100 bg-white shadow-sm overflow-hidden" data-week-card>
        <button type="button"
                class="w-full flex items-center justify-between px-6 py-4 text-left transition hover:bg-gray-50"
                onclick="toggleWeek({{ w }})"
                aria-expanded="false"
                data-week-toggle="{{ w }}">
            <div class="flex items-center gap-4 min-w-0">
                <div class="flex h-10 w-10 items-center justify-center rounded-2xl text-sm font-semibold"
                     style="background-color:{% if hasMaterials %}#e8f2ea;color:#0b3612;{% else %}#f3f4f6;color:#6b7280;{% endif %};">
                    W{{ '%02d'|format(w) }}
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 truncate">Week {{ w }}</p>
                    {% if week and week.title matches '/^Week \d+$/' == false %}
                        <p class="text-xs text-gray-500 truncate">{{ week.title }}</p>
                    {% endif %}
                    <p class="text-xs text-gray-400">{{ hasMaterials ? week.materials|length : 0 }} file{{ hasMaterials and week.materials|length != 1 ? 's' : '' }}</p>
                </div>
            </div>
            <svg class="w-4 h-4 text-gray-400 transition-transform duration-200" data-week-chevron="{{ w }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
        </button>

        <div class="border-t border-gray-100 px-6 py-5 hidden" data-week-panel="{{ w }}">
            {% if hasMaterials %}
                <ul class="space-y-2">
                    {% for material in week.materials %}
                    <li class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl border border-gray-100 hover:border-emerald-100 hover:bg-emerald-50/40 transition">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background-color:#ecfdf5;color:#0b3612;">
                                <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-gray-800 truncate">{{ material.originalName }}</p>
                                <p class="text-xs text-gray-400">{{ material.uploadedAt|date('M d, Y') }}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <button type="button"
                                    onclick="openPdfViewer('{{ asset('uploads/materials/' ~ material.filename) }}', '{{ material.originalName|e('html_attr') }}')"
                                    class="text-xs font-semibold px-3 py-1.5 rounded-lg text-white flex items-center gap-1.5 bg-emerald-900 hover:bg-emerald-800 transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                View
                            </button>
                            <a href="{{ asset('uploads/materials/' ~ material.filename) }}"
                               download="{{ material.originalName }}"
                               class="text-xs font-semibold px-3 py-1.5 rounded-lg flex items-center gap-1.5 bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                </svg>
                                Download
                            </a>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="text-sm text-gray-400 py-2 text-center">No materials uploaded for this week yet.</p>
            {% endif %}

            {% if week and week.isSubmissionRequired %}
                <div class="mt-6 border-t border-gray-100 pt-5">
                    <div class="flex items-center justify-between mb-4">
                        <h4 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                            Assignment Submission
                        </h4>
                    </div>

                    <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6">
                        {% set weekSubmissions = submissionsByWeek[week.id] ?? [] %}
                        {% set totalUploaded = weekSubmissions|length %}
                        {% set maxFiles = week.maxFiles|default(1) %}
                        {% set canUploadMore = totalUploaded < maxFiles %}

                        <div class="flex items-center justify-between mb-6">
                            <div>
                                {% if totalUploaded > 0 %}
                                    <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-md text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        Submitted ({{ totalUploaded }}/{{ maxFiles }})
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-md text-xs font-medium bg-yellow-50 text-yellow-800 border border-yellow-200">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        Pending Submission
                                    </span>
                                {% endif %}
                            </div>
                            <div class="text-xs text-gray-500 flex items-center gap-1.5">
                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                {% if canUploadMore %}
                                    You can upload {{ maxFiles - totalUploaded }} more file{% if (maxFiles - totalUploaded) > 1 %}s{% endif %}
                                {% else %}
                                    Maximum files reached
                                {% endif %}
                            </div>
                        </div>

                        {% if totalUploaded > 0 %}
                            <div class="mb-6">
                                <h5 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Your Files</h5>
                                <ul class="space-y-2.5">
                                    {% for sub in weekSubmissions %}
                                    <li class="flex flex-col gap-2 p-4 rounded-xl border border-gray-200 bg-white shadow-sm hover:border-emerald-100 hover:shadow-md transition">
                                        <div class="flex items-center justify-between gap-3">
                                            <div class="flex items-center gap-3 min-w-0">
                                                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 {% if sub.status == 'graded' %}bg-green-50 text-green-700{% else %}bg-blue-50 text-blue-700{% endif %}">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                                    </svg>
                                                </div>
                                                <div class="min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">{{ sub.originalName|default(sub.filename|default('Submission')) }}</p>
                                                    <p class="text-xs text-gray-500 mt-0.5">Uploaded on {{ sub.uploadedAt|date('M d, Y \\a\\t h:i A') }}</p>
                                                </div>
                                            </div>
                                            <div class="shrink-0 flex items-center gap-2">
                                                {% if sub.status == 'graded' %}
                                                    <span class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full text-xs font-bold shadow-sm" style="background-color:#e8f2ea;color:#0b3612;">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                                        Graded: {{ sub.grade }}
                                                    </span>
                                                {% else %}
                                                    <span class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full text-xs font-bold shadow-sm bg-yellow-100 text-yellow-800">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                        Pending
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% if sub.status == 'graded' and sub.feedback %}
                                            <div class="mt-2 text-sm text-gray-700 bg-gray-50 p-3 rounded-md border border-gray-100">
                                                <span class="font-semibold text-xs text-gray-500 uppercase block mb-1">Trainer Feedback</span>
                                                {{ sub.feedback|nl2br }}
                                            </div>
                                        {% endif %}
                                    </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        <form action="{{ path('app_student_submission_upload', {courseId: course.id, weekId: week.id}) }}" method="POST" enctype="multipart/form-data" class="flex flex-col gap-4 {% if not canUploadMore %}opacity-50 pointer-events-none{% endif %}">
                            <div class="flex items-center justify-center w-full">
                                <label for="dropzone-file-{{ week.id }}" class="flex flex-col items-center justify-center w-full h-36 border-2 border-dashed rounded-xl cursor-pointer bg-white border-gray-200 hover:border-emerald-200 hover:bg-emerald-50/40 transition-all">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6 text-center px-4">
                                        <svg class="w-8 h-8 mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                                        </svg>
                                        <p class="mb-1 text-sm text-gray-600"><span class="font-semibold text-gray-800">Click to browse</span> or drag & drop</p>
                                        <p class="text-xs text-gray-400 mt-1">
                                            {% if week.allowedFileTypes and week.allowedFileTypes|length > 0 %}
                                                Accepts {{ week.allowedFileTypes|join(', ')|upper }}
                                            {% else %}
                                                Any file type accepted
                                            {% endif %}
                                        </p>
                                    </div>
                                    <input id="dropzone-file-{{ week.id }}" type="file" name="submission_files[]" class="hidden"
                                        {% if week.allowedFileTypes and week.allowedFileTypes|length > 0 %}
                                            {% set acceptParts = [] %}
                                            {% for type in week.allowedFileTypes %}
                                                {% if type == 'pdf' %}{% set acceptParts = acceptParts|merge(['.pdf', 'application/pdf']) %}{% endif %}
                                                {% if type == 'word' %}{% set acceptParts = acceptParts|merge(['.doc', '.docx', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document']) %}{% endif %}
                                                {% if type == 'image' %}{% set acceptParts = acceptParts|merge(['image/*']) %}{% endif %}
                                            {% endfor %}
                                            accept="{{ acceptParts|join(',') }}"
                                        {% endif %}
                                        {% if maxFiles > 1 %}multiple{% endif %}
                                        {% if not canUploadMore %}disabled{% endif %}
                                    >
                                </label>
                            </div>

                            <button type="submit"
                                    class="text-sm font-semibold text-white px-5 py-2.5 rounded-xl transition w-full flex items-center justify-center gap-2 shadow-sm cursor-pointer bg-emerald-900 hover:bg-emerald-800"
                                    {% if not canUploadMore %}disabled{% endif %}>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                Upload & Submit
                            </button>
                        </form>
                    </div>
                </div>
            {% endif %}
        </div>

    </div>
{% endfor %}
</div>
</section>

<script>
function toggleWeek(n) {
    const panel = document.querySelector('[data-week-panel="' + n + '"]');
    const chevron = document.querySelector('[data-week-chevron="' + n + '"]');
    const toggle = document.querySelector('[data-week-toggle="' + n + '"]');
    if (!panel || !chevron || !toggle) {
        return;
    }

    const isHidden = panel.classList.contains('hidden');
    panel.classList.toggle('hidden');
    chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
    toggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
}

function openPdfViewer(url, name) {
    const modal = document.getElementById('pdf-viewer-modal');
    document.getElementById('pdf-viewer-title').textContent = name;
    document.getElementById('pdf-viewer-frame').src = url;
    document.getElementById('pdf-viewer-download').href = url;
    document.getElementById('pdf-viewer-download').setAttribute('download', name);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
}

function closePdfViewer() {
    const modal = document.getElementById('pdf-viewer-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.getElementById('pdf-viewer-frame').src = '';
    document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePdfViewer();
});

document.addEventListener('DOMContentLoaded', function () {
    const firstToggle = document.querySelector('[data-week-toggle]');
    if (firstToggle) {
        toggleWeek(firstToggle.getAttribute('data-week-toggle'));
    }
});
</script>

{# ── PDF Viewer Modal ── #}
<div id="pdf-viewer-modal" class="fixed inset-0 z-50 hidden flex-col bg-black/70" onclick="if(event.target===this) closePdfViewer()">
    <div class="mx-auto flex h-full w-full max-w-4xl flex-col rounded-none bg-white shadow-2xl">
        <div class="flex items-center justify-between gap-3 border-b border-gray-100 px-5 py-4">
            <div class="flex items-center gap-3 min-w-0">
                <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <span id="pdf-viewer-title" class="truncate text-sm font-semibold text-gray-900"></span>
            </div>
            <div class="flex items-center gap-2">
                <a id="pdf-viewer-download" href="#" download class="inline-flex items-center gap-1 rounded-xl bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    Download
                </a>
                <button type="button" onclick="closePdfViewer()" class="flex h-9 w-9 items-center justify-center rounded-xl bg-gray-100 text-gray-500 hover:bg-gray-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
        <iframe id="pdf-viewer-frame" src="" class="h-full w-full flex-1 bg-slate-800" allowfullscreen></iframe>
    </div>
</div>

{% endblock %}
