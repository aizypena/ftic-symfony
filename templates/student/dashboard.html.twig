{% extends 'student/base.html.twig' %}

{% block title %}Student Dashboard – FTIC{% endblock %}

{% block body %}
<div>

    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Student Dashboard</h1>
            <p class="text-gray-500 mt-1">Welcome back, <span class="font-medium text-feu-light">{{ user.displayName }}</span></p>
        </div>
        <span class="inline-flex items-center gap-1.5 bg-feu-pale text-feu-dark text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/></svg>
            Student
        </span>
    </div>

    <div class="mb-6">

        {# Announcements — full width #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm flex flex-col overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                </svg>
                <h2 class="text-base font-semibold text-gray-900">Announcements</h2>
            </div>
            {% if announcements|length > 0 %}
            <ul class="divide-y divide-gray-50 overflow-y-auto" style="max-height:380px;">
                {% for ann in announcements %}
                <li class="px-6 py-4">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <p class="text-sm font-semibold text-gray-900">{{ ann.title }}</p>
                        <span class="text-xs text-gray-400">{{ ann.createdAt|date('M d, Y · g:i A') }}</span>
                    </div>
                    <p class="text-sm text-gray-500 whitespace-pre-line mb-2">{{ ann.content }}</p>
                    {% if ann.imageFilename %}
                    <img src="{{ asset('uploads/announcements/' ~ ann.imageFilename) }}"
                         alt="Announcement image"
                         style="max-height:200px; max-width:100%; object-fit:cover; border-radius:8px; border:1px solid #e5e7eb;">
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <div class="flex flex-col items-center justify-center py-14 text-center text-gray-400 flex-1">
                <svg class="w-10 h-10 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                </svg>
                <p class="text-sm font-medium text-gray-500">No announcements yet</p>
            </div>
            {% endif %}
        </div>
    </div>

    {# My Courses — full width #}
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-900">My Courses</h2>
            <a href="{{ path('app_student_courses') }}" class="text-xs font-medium hover:underline" style="color:#0b3612;">View all →</a>
        </div>
        {% if myCourses|length > 0 %}
        <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
            {% for course in myCourses|slice(0, 6) %}
            <li>
                <a href="{{ path('app_student_course_view', {id: course.id}) }}"
                   class="flex items-center justify-between px-4 py-3 rounded-lg border border-gray-100 hover:border-feu-light hover:bg-feu-pale transition group">
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-gray-800 group-hover:text-feu-dark truncate">{{ course.name }}</p>
                        <p class="text-xs text-gray-400 mt-0.5">
                            {{ course.trainer ? course.trainer.displayName : 'No trainer' }} &middot; {{ course.weeks|length }} weeks
                            {% if course.term %}&middot; {{ course.term.schoolYear }} - {{ course.term.termLabel }}{% endif %}
                        </p>
                    </div>
                    {% if course.status == 'active' %}
                        <span class="text-xs font-semibold px-2 py-1 rounded-full shrink-0 ml-2" style="background-color:#e8f2ea;color:#0b3612;">Active</span>
                    {% else %}
                        <span class="text-xs font-semibold px-2 py-1 rounded-full bg-gray-100 text-gray-500 shrink-0 ml-2">Inactive</span>
                    {% endif %}
                </a>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <div class="flex flex-col items-center justify-center py-10 text-center text-gray-400">
            <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            <p class="text-sm font-medium text-gray-500">Not enrolled in any courses yet</p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
