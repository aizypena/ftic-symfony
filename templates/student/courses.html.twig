{% extends 'student/base.html.twig' %}

{% block title %}My Courses – FTIC Student{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Courses</h1>
    <p class="text-sm text-gray-500 mt-1">Courses you are currently enrolled in</p>
</div>

{% if myCourses|length > 0 %}
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
    {% for course in myCourses %}
    <a href="{{ path('app_student_course_view', {id: course.id}) }}"
       class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 flex flex-col gap-3 hover:shadow-md hover:border-feu-light transition group">

        {# Status badge #}
        <div class="flex items-center justify-between">
            {% if course.status == 'active' %}
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color:#e8f2ea;color:#0b3612;">Active</span>
            {% else %}
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-gray-100 text-gray-500">Inactive</span>
            {% endif %}
            <span class="text-xs text-gray-400">{{ course.weeks|length }} week{{ course.weeks|length != 1 ? 's' : '' }}</span>
        </div>

        {# Course name #}
        <div>
            <h2 class="text-base font-bold text-gray-900 group-hover:text-feu-dark leading-tight">{{ course.name }}</h2>
            {% if course.description %}
                <p class="text-xs text-gray-500 mt-1 line-clamp-2">{{ course.description }}</p>
            {% endif %}
        </div>

        {# Trainer #}
        <div class="flex items-center gap-2 mt-auto pt-3 border-t border-gray-50">
            <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-500 shrink-0">
                {{ course.trainer ? course.trainer.displayName|first|upper : '?' }}
            </div>
            <span class="text-xs text-gray-500">{{ course.trainer ? course.trainer.displayName : 'No trainer assigned' }}</span>
        </div>
    </a>
    {% endfor %}
</div>
{% else %}
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-16 text-center">
    <svg class="w-14 h-14 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
    </svg>
    <p class="text-gray-500 font-medium">You are not enrolled in any courses yet</p>
    <p class="text-sm text-gray-400 mt-1">Contact your admin to get enrolled in a course</p>
</div>
{% endif %}
{% endblock %}
