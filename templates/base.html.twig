<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}FTIC{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">

        {% block navbar %}
        <nav class="bg-white border-b border-gray-200 shadow-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16 items-center">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-3">
                        <img src="{{ asset('tamlabs-nav.jpeg') }}" alt="Far Eastern University Training & Innovation Center" class="h-9 w-auto object-contain">
                    </a>
                    <div class="flex items-center gap-4">
                        {% if app.user %}
                            <span class="text-sm text-gray-600">{{ app.user.displayName }}</span>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_dashboard') }}" class="text-sm font-medium text-feu-dark hover:text-feu-light transition">Dashboard</a>
                            {% elseif is_granted('ROLE_TRAINER') %}
                                <a href="{{ path('app_trainer_dashboard') }}" class="text-sm font-medium text-feu-dark hover:text-feu-light transition">Dashboard</a>
                            {% else %}
                                <a href="{{ path('app_student_dashboard') }}" class="text-sm font-medium text-feu-dark hover:text-feu-light transition">Dashboard</a>
                            {% endif %}
                            <a href="{{ path('app_logout') }}" class="text-sm font-medium bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-lg transition">Logout</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white shadow-md transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-feu-dark" style="background-color:#0b3612;box-shadow:0 10px 20px rgba(11,54,18,0.25);">
                                <span>Login</span>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>
        {% endblock %}

        {% block body %}{% endblock %}

        {% block footer %}
        <footer class="mt-auto py-6 border-t border-gray-200 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-500">
                &copy; {{ "now"|date("Y") }} FTIC. All rights reserved.
            </div>
        </footer>
        {% endblock %}
    {{ include('partials/_toast.html.twig') }}
    {{ include('partials/_confirm_modal.html.twig') }}
    </body>
</html>
