{% extends 'base.html.twig' %}

{% block title %}FTIC – Welcome{% endblock %}

{% block body %}
{# Hero #}
<section class="relative bg-gradient-to-br from-feu-dark via-[#0d4016] to-feu-light text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
            Welcome to <span class="text-yellow-300">FTIC</span>
        </h1>
        <p class="text-lg sm:text-xl text-feu-muted max-w-2xl mx-auto mb-10">
            A powerful platform designed to streamline your workflow, manage your data, and keep your team aligned — all in one place.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            {% if app.user %}
                <a href="{{ path('app_dashboard') }}"
                   class="inline-block bg-white text-feu-dark font-semibold px-8 py-3 rounded-xl shadow-lg hover:bg-feu-pale transition text-lg">
                    Go to Dashboard
                </a>
            {% else %}
                <a href="{{ path('app_login') }}"
                   class="inline-block bg-white text-feu-dark font-semibold px-8 py-3 rounded-xl shadow-lg hover:bg-feu-pale transition text-lg">
                    Get Started
                </a>
                <a href="#features"
                   class="inline-block border border-white text-white font-semibold px-8 py-3 rounded-xl hover:bg-white/10 transition text-lg">
                    Learn More
                </a>
            {% endif %}
        </div>
    </div>
</section>

{# Features #}
<section id="features" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <h2 class="text-3xl font-bold text-gray-900 mb-3">Everything you need</h2>
            <p class="text-gray-500 text-lg max-w-xl mx-auto">Built with modern tools to give you speed, security, and simplicity.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Fast & Reliable</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Optimized for performance with a modern Symfony backend and asset mapper pipeline.</p>
            </div>

            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Secure by Default</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Role-based access control, CSRF protection, and hashed passwords out of the box.</p>
            </div>

            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Modular Design</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Clean architecture that makes it easy to extend and scale your application.</p>
            </div>

            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Insightful Dashboard</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Get a bird's-eye view of your data and activity from a clean, intuitive dashboard.</p>
            </div>

            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Team Ready</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Built with collaboration in mind — manage roles, users, and permissions with ease.</p>
            </div>

            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-md transition">
                <div class="w-12 h-12 bg-feu-pale rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-feu-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Fully Configurable</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Symfony's powerful configuration system lets you tailor every aspect of the app.</p>
            </div>
        </div>
    </div>
</section>

{# CTA #}
<section class="bg-feu-dark py-16 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
        <p class="text-feu-muted mb-8 text-lg">Sign in to your account and take control of your workflow today.</p>
        {% if not app.user %}
            <a href="{{ path('app_login') }}"
               class="inline-block bg-white text-feu-dark font-semibold px-8 py-3 rounded-xl shadow-lg hover:bg-feu-pale transition text-lg">
                Sign In Now
            </a>
        {% else %}
            <a href="{{ path('app_dashboard') }}"
               class="inline-block bg-white text-feu-dark font-semibold px-8 py-3 rounded-xl shadow-lg hover:bg-feu-pale transition text-lg">
                Go to Dashboard
            </a>
        {% endif %}
    </div>
</section>
{% endblock %}
