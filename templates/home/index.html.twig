{% extends 'base.html.twig' %}

{% block title %}FTIC – Welcome{% endblock %}

{% block body %}

{# ── Hero Carousel ── #}
<section class="relative w-full overflow-hidden" style="height:520px;">

    {# Slides — using placeholder images with school-themed colors #}
    <div id="carousel" class="flex h-full transition-transform duration-700 ease-in-out" style="width:300%;">

        <div class="relative w-1/3 h-full flex-shrink-0 flex items-center justify-center" style="background-color:#0b3612;">
            <img src="https://images.unsplash.com/photo-1562774053-701939374585?w=1400&q=80&auto=format&fit=crop"
                 alt="Campus" class="absolute inset-0 w-full h-full object-cover opacity-40">
            <div class="relative text-center text-white px-6 z-10">
                <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">Far Eastern University</h1>
                <p class="text-lg sm:text-xl font-medium mb-6" style="color:#c4d9c8;">Training & Innovation Center</p>
                {% if not app.user %}
                <a href="{{ path('app_login') }}" class="inline-flex items-center gap-2 rounded-full bg-feu-dark px-8 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-feu-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-feu-dark">
                    Get Started
                </a>
                {% else %}
                <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-full bg-feu-dark px-8 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-feu-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-feu-dark">
                    Go to Dashboard
                </a>
                {% endif %}
            </div>
        </div>

        <div class="relative w-1/3 h-full flex-shrink-0 flex items-center justify-center" style="background-color:#0b3612;">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1400&q=80&auto=format&fit=crop"
                 alt="Students" class="absolute inset-0 w-full h-full object-cover opacity-40">
            <div class="relative text-center text-white px-6 z-10">
                <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">Empowering Learners</h2>
                <p class="text-lg sm:text-xl font-medium" style="color:#c4d9c8;">Providing quality training programs for every student</p>
            </div>
        </div>

        <div class="relative w-1/3 h-full flex-shrink-0 flex items-center justify-center" style="background-color:#0b3612;">
            <img src="https://images.unsplash.com/photo-1588702547919-26089e690ecc?w=1400&q=80&auto=format&fit=crop"
                 alt="Training" class="absolute inset-0 w-full h-full object-cover opacity-40">
            <div class="relative text-center text-white px-6 z-10">
                <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">Expert-Led Training</h2>
                <p class="text-lg sm:text-xl font-medium" style="color:#c4d9c8;">Learn from experienced professionals in your field</p>
            </div>
        </div>

    </div>

    {# Prev / Next buttons #}
    <button onclick="changeSlide(-1)" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/20 hover:bg-white/40 text-white flex items-center justify-center transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button onclick="changeSlide(1)" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/20 hover:bg-white/40 text-white flex items-center justify-center transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    {# Dots #}
    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-20">
        <button onclick="goToSlide(0)" id="dot-0" class="w-2.5 h-2.5 rounded-full bg-white transition"></button>
        <button onclick="goToSlide(1)" id="dot-1" class="w-2.5 h-2.5 rounded-full bg-white/40 transition"></button>
        <button onclick="goToSlide(2)" id="dot-2" class="w-2.5 h-2.5 rounded-full bg-white/40 transition"></button>
    </div>
</section>

{# ── Announcements strip ── #}
<div class="border-y border-gray-200 bg-white py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-3 text-sm">
        <span class="shrink-0 font-bold text-white text-xs px-3 py-1 rounded" style="background-color:#0b3612;">ANNOUNCEMENT</span>
        <p class="text-gray-600 truncate">Enrollment for the 2nd semester is now open. Please visit the registrar's office for more information.</p>
    </div>
</div>

{# ── Features ── #}
<section class="bg-gray-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900">What FTIC Offers</h2>
            <p class="text-gray-500 mt-2 text-sm">Everything you need in one platform</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-7 text-center">
                <div class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center" style="background-color:#e8f2ea;">
                    <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-2">Structured Courses</h3>
                <p class="text-sm text-gray-500">Access well-organized training materials and course content designed by experts.</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-7 text-center">
                <div class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center" style="background-color:#e8f2ea;">
                    <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-2">Role-Based Access</h3>
                <p class="text-sm text-gray-500">Separate dashboards for admins, trainers, and students — everyone sees what they need.</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-7 text-center">
                <div class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center" style="background-color:#e8f2ea;">
                    <svg class="w-6 h-6" style="color:#0b3612;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-2">Schedule Management</h3>
                <p class="text-sm text-gray-500">Stay on top of your classes and training sessions with a built-in calendar.</p>
            </div>
        </div>
    </div>
</section>

{# ── CTA ── #}
<section class="py-16 text-white text-center" style="background-color:#0b3612;">
    <div class="max-w-2xl mx-auto px-4">
        <h2 class="text-3xl font-bold mb-3">Ready to get started?</h2>
        <p class="mb-8 text-sm" style="color:#c4d9c8;">Sign in to access your personalized dashboard and begin your training journey.</p>
        {% if not app.user %}
            <a href="{{ path('app_login') }}" class="inline-flex items-center gap-2 rounded-full bg-feu-dark px-8 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-feu-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-feu-dark">
                Sign In Now
            </a>
        {% else %}
            <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-full bg-feu-dark px-8 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-feu-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-feu-dark">
                Go to Dashboard
            </a>
        {% endif %}
    </div>
</section>

{# ── Footer ── #}
<footer class="bg-white border-t border-gray-200 py-8 text-center text-xs text-gray-400">
    &copy; {{ "now"|date("Y") }} Far Eastern University – Training & Innovation Center. All rights reserved.
</footer>

<script>
    let current = 0;
    const total = 3;

    function updateCarousel() {
        document.getElementById('carousel').style.transform = `translateX(-${current * (100 / total)}%)`;
        for (let i = 0; i < total; i++) {
            document.getElementById('dot-' + i).style.backgroundColor = i === current ? 'white' : 'rgba(255,255,255,0.4)';
        }
    }

    function changeSlide(dir) {
        current = (current + dir + total) % total;
        updateCarousel();
    }

    function goToSlide(index) {
        current = index;
        updateCarousel();
    }

    // Auto-advance every 5 seconds
    setInterval(() => changeSlide(1), 5000);
</script>

{% endblock %}

